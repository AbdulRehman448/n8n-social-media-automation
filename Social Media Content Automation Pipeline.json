    {
      "parameters": {
        "jsCode": "const newArticles = $('Check Skip').all();\nconst existingPosts = $input.all();\n\n// Get all existing URLs\nconst existingUrls = existingPosts\n  .map(p => p.json.source_url || '')\n  .filter(url => url !== '');\n\n// Filter out duplicates\nconst unique = newArticles.filter(article => {\n  return !existingUrls.includes(article.json.source_url);\n});\n\nif (unique.length === 0) {\n  return [{ json: { skip: true, message: 'All articles already posted' } }];\n}\n\nreturn unique;"
      },
