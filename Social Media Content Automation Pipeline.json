    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a LinkedIn content expert. Create an engaging LinkedIn post based on this article:\n\nTitle: {{ $json.title }}\nCategory: {{ $json.category }}\nSummary: {{ $json.summary }}\nSource: {{ $json.source_url }}\n\nWrite a LinkedIn post that:\n- Starts with a strong hook (question or bold statement)\n- Shares 2-3 key insights from the article\n- Relates it to AI automation or business growth\n- Ends with a thought-provoking question to drive engagement\n- Includes 3-5 relevant hashtags at the end\n- Is between 150-250 words\n- Sounds human, not robotic\n\nReturn only the post text. No extra explanation.",
        "batching": {}
      },
      "id": "72d798b8-4039-45da-969e-c6aeafab3f9a",
      "name": "Generate LinkedIn Post",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        1584,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst articles = $('Check Duplicate Skip').all();\n\nreturn items.map((item, index) => {\n  const article = articles[index]?.json || {};\n  return {\n    json: {\n      title: article.title || '',\n      source_url: article.source_url || '',\n      category: article.category || '',\n      generated_post: item.json.text || '',\n      status: 'Ready',\n      created_at: new Date().toLocaleString('en-PK', { timeZone: 'Asia/Karachi' })\n    }\n  };\n});"
      },
