    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const title = item.json.title || '';\n  const link = item.json.link || '';\n  const summary = item.json.contentSnippet || item.json.summary || item.json.content || '';\n  const category = item.json.category || 'Technology';\n  const pubDate = item.json.pubDate || item.json.isoDate || new Date().toISOString();\n\n  // Only include recent articles (last 24 hours)\n  const articleDate = new Date(pubDate);\n  const now = new Date();\n  const hoursDiff = (now - articleDate) / (1000 * 60 * 60);\n\n  if (hoursDiff <= 24 && title && link) {\n    results.push({\n      json: {\n        title: title.substring(0, 200),\n        source_url: link,\n        category: category,\n        summary: summary.substring(0, 500),\n        pub_date: pubDate\n      }\n    });\n  }\n}\n\nif (results.length === 0) {\n  return [{ json: { skip: true, message: 'No recent articles found' } }];\n}\n\n// Return max 3 articles to avoid Gemini rate limits\nreturn results.slice(0, 3);"
      },
